        {
          "id": "policy_hr",
          "label": "Follow HR Policy",
          "fields": [
            {
              "id": "managerRating",
              "label": "Manager Rating (1-10)",
              "type": "rating",
              "ratingScale": "policy_1_10",
              "editableBy": "manager",
              "required": true,
