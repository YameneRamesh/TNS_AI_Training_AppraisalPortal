{
  "version": "3.0",
  "name": "TnS Appraisal Form V3.0 (2025-26)",
  "description": "Think n Solutions Annual Performance Appraisal Form",
  "sections": [
    {
      "sectionType": "header",
      "title": "Appraisal Header",
      "fields": [
        {
          "id": "teamMemberName",
          "label": "Team Member Name",
          "type": "text",
          "readOnly": true,
          "source": "employee.fullName"
        },
        {
          "id": "dateOfHire",
          "label": "Date of Hire",
          "type": "date",
          "readOnly": true,
          "source": "employee.dateOfHire"
        },
        {
          "id": "designation",
          "label": "Designation",
          "type": "text",
          "readOnly": true,
          "source": "employee.designation"
        },
        {
          "id": "dateOfReview",
          "label": "Date of Review",
          "type": "date",
          "readOnly": false
        },
        {
          "id": "managerName",
          "label": "Manager Name",
          "type": "text",
          "readOnly": true,
          "source": "manager.fullName"
        },
        {
          "id": "reviewPeriod",
          "label": "Review Period",
          "type": "text",
          "readOnly": false
        },
        {
          "id": "typeOfReview",
          "label": "Type of Review",
          "type": "text",
          "readOnly": false,
          "defaultValue": "Annual"
        }
      ]
    },
    {
      "sectionType": "rating_key",
      "title": "Rating Key",
      "description": "Performance rating scale definitions",
      "ratings": [
        {
          "value": "Excels",
          "description": "Consistently exceeds expectations and demonstrates exceptional performance"
        },
        {
          "value": "Exceeds",
          "description": "Frequently exceeds expectations and shows strong performance"
        },
        {
          "value": "Meets",
          "description": "Consistently meets expectations and performs satisfactorily"
        },
        {
          "value": "Developing",
          "description": "Performance is below expectations and requires improvement"
        }
      ]
    },
    {
      "sectionType": "overall_evaluation",
      "title": "Overall Evaluation Rating",
      "fields": [
        {
          "id": "managerComments",
          "label": "Manager's Comments",
          "type": "textarea",
          "editableBy": "manager",
          "required": true
        },
        {
          "id": "teamMemberComments",
          "label": "Team Member's Comments",
          "type": "textarea",
          "editableBy": "employee",
          "required": false
        }
      ]
    },
    {
